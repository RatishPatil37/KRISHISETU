# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# Kindwise Crop Health API Key
# Get free key at: https://kindwise.com (100 req/month free)
KINDWISE_API_KEY=your_kindwise_api_key_here

# Gemini / Google AI
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firecrawl (optional - for live scheme sync)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Twilio (optional - for WhatsApp notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Port
PORT=5000
